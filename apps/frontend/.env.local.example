# ============================================================================
# frontend (@sanrentan-party/frontend) 環境変数
# このファイルを apps/frontend/.env.local にコピーして設定する。
# Next.js は app ディレクトリ（apps/frontend）の .env.local を読む。
# ============================================================================

# BFF (Route Handler) がサーバ側で backend を叩くベース URL。
# クライアントには露出しない（x-user-* はこの経路でサーバが付与する）。
BACKEND_API_URL="http://localhost:3001/api"
