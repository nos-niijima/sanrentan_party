# ============================================================================
# backend (@sanrentan-party/backend) 環境変数
# このファイルを apps/backend/.env にコピーして設定する。
# backend は cwd=apps/backend で起動するため ConfigModule / prisma.config は
# この .env を読む。
# ============================================================================

# Database （docker-compose は 5433->5432 にマップ）
DATABASE_URL="postgresql://dev_user:dev_password@localhost:5433/sanrentan_party"

# Server
PORT=3001
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000"

# レート制限
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ログ
LOG_LEVEL="log"
